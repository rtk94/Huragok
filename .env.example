# Huragok runtime configuration.
#
# This file is for human reference only. Copy it to `.env` and fill in the
# variables you need. `.env` is gitignored — NEVER commit it.
#
# Variables without the HURAGOK_ prefix are read directly, matching the
# conventional env var names operators already use for those services.

# --- Authentication (choose one) -------------------------------------------
#
# Option A (recommended for Claude Max subscribers): use cached OAuth
# credentials from `claude login`. No env var is required for the daemon
# when running interactively — the session runner inherits HOME and
# Claude Code finds ~/.claude/.credentials.json on its own.
#
# For systemd deployment or any environment where ~/.claude/ isn't
# accessible to the daemon (isolated home, LoadCredential, containers),
# generate a long-lived token with `claude setup-token` and set:
#
#   CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
#
# Option B (pay-as-you-go via API credits): set an API key. Sessions
# run against your Console account's API credit balance, NOT your Max
# subscription. When both this variable and cached OAuth credentials
# are present, the API key wins (per Claude Code's auth precedence).
#
#   ANTHROPIC_API_KEY=sk-ant-api-...
#
# WARNING: setting ANTHROPIC_API_KEY on a Max-subscribed machine
# silently routes billing to API credits — work that would otherwise be
# covered by your Max plan now costs real dollars. Do not set both
# unless that's what you want.

# Optional: Admin API key for Cost API reconciliation (ADR-0002 D4).
# Not required — the daemon runs on table-only dollar estimates without
# it. REPLACE WITH YOUR ACTUAL ADMIN KEY if used.
# ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-...

# --- Telegram notifications (optional) -------------------------------------

# Telegram bot token for the notification dispatcher (ADR-0002 D6).
# Without a token the daemon falls back to the no-network
# LoggingDispatcher and batches still run — just without mobile pings.
# REPLACE WITH YOUR ACTUAL BOT TOKEN
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Default Telegram chat ID to receive notifications when batch.yaml does not
# specify one. String, not int — Telegram chat IDs can be negative.
# REPLACE WITH THE CHAT ID YOU WANT NOTIFICATIONS SENT TO
# HURAGOK_TELEGRAM_DEFAULT_CHAT_ID=

# --- Huragok-specific settings (HURAGOK_ prefix) ---------------------------

# Log level: debug | info | warn | error | critical.
HURAGOK_LOG_LEVEL=info

# Optional override for `.huragok/` root discovery. Used in tests.
# HURAGOK_DATA_DIR=
