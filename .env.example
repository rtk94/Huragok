# Huragok runtime configuration.
#
# This file is for human reference only. Copy it to `.env` and fill in the
# variables you need. `.env` is gitignored — NEVER commit it.
#
# Variables without the HURAGOK_ prefix are read directly, matching the
# conventional env var names operators already use for those services.

# --- Secrets ----------------------------------------------------------------

# Anthropic API key used by the outer orchestrator to launch Claude Code
# sessions. Required for Slice B; optional in Slice A.
# REPLACE WITH YOUR ACTUAL API KEY
ANTHROPIC_API_KEY=

# Anthropic Admin API key for Cost API reconciliation (ADR-0002 D4).
# Optional — omit and Huragok runs on table-only dollar estimates.
# REPLACE WITH YOUR ACTUAL ADMIN KEY
ANTHROPIC_ADMIN_API_KEY=

# Telegram bot token for the notification dispatcher (ADR-0002 D6).
# Optional in Slice A.
# REPLACE WITH YOUR ACTUAL BOT TOKEN
TELEGRAM_BOT_TOKEN=

# --- Huragok-specific settings (HURAGOK_ prefix) ---------------------------

# Default Telegram chat ID to receive notifications when batch.yaml does not
# specify one. String, not int — Telegram chat IDs can be negative.
HURAGOK_TELEGRAM_DEFAULT_CHAT_ID=

# Log level: debug | info | warn | error | critical.
HURAGOK_LOG_LEVEL=info

# Optional override for `.huragok/` root discovery. Used in tests.
# HURAGOK_DATA_DIR=
